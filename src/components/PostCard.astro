---
import type { CollectionEntry } from 'astro:content';
import Cover from './Cover.astro';
import CategoryTag from './CategoryTag.astro';
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category } = post.data;
---

<a class="card" href={`/blog/${post.id}/`}>
	<Cover title={title} category={category} variant="card" />
	<div class="body">
		<div class="meta">
			<CategoryTag category={category} />
			<span class="date"><FormattedDate date={pubDate} /></span>
		</div>
		<h3 class="title">{title}</h3>
		<p class="excerpt">{description}</p>
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		background: var(--paper-raised);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		overflow: hidden;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-color 0.15s ease;
	}
	.card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow);
		border-color: var(--accent);
	}
	.body {
		padding: 1.1rem 1.2rem 1.3rem;
	}
	.meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.6rem;
		margin-bottom: 0.5rem;
	}
	.date {
		font-size: 0.8rem;
		color: var(--ink-soft);
	}
	.title {
		font-family: var(--font-serif), Georgia, serif;
		font-weight: 900;
		font-size: 1.25rem;
		line-height: 1.35;
		margin: 0 0 0.4rem;
		color: var(--ink-strong);
	}
	.card:hover .title {
		color: var(--accent-strong);
	}
	.excerpt {
		margin: 0;
		font-size: 0.94rem;
		color: var(--ink-soft);
		line-height: 1.7;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
