---
import { SITE_TITLE, SOCIAL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">{SITE_TITLE}</a>
		<div class="internal-links">
			<HeaderLink href="/">首頁</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">關於</HeaderLink>
		</div>
		<div class="social-links">
			{
				SOCIAL.line && (
					<a href={SOCIAL.line} target="_blank" rel="noopener" aria-label="LINE">
						<span class="sr-only">LINE</span>
						<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12 2C6.48 2 2 5.69 2 10.23c0 4.07 3.58 7.48 8.41 8.12.33.07.77.22.88.5.1.26.07.66.03.92l-.14.85c-.04.26-.2 1.02.89.56 1.09-.46 5.86-3.45 8-5.91 1.47-1.62 2.18-3.27 2.18-5.04C22 5.69 17.52 2 12 2z"
							/>
						</svg>
					</a>
				)
			}
			{
				SOCIAL.threads && (
					<a
						href={SOCIAL.threads}
						target="_blank"
						rel="noopener"
						aria-label="Threads"
					>
						<span class="sr-only">Threads</span>
						<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12.5 2C6.9 2 3.6 5.3 3.5 11.9 3.6 18.6 6.9 22 12.5 22c4 0 6.6-2.1 7.4-5.2.3-1.2.2-2.5-.4-3.5-.7-1.2-2-2-3.6-2.2.1-1.6-.6-2.9-2.4-3-1.6-.1-2.7.8-3 2l1.7.5c.2-.7.7-1 1.3-.9.7.1 1 .6.9 1.5-2.6-.1-4.6 1-4.7 3.2-.1 1.9 1.4 3.1 3.3 3.1 2 0 3.3-1.3 3.7-3.3.7.2 1.2.6 1.5 1.1.3.6.4 1.3.2 2-.5 2-2.3 3.2-5.1 3.2-4.4 0-6.6-2.5-6.7-8.1C5.9 6.3 8.1 3.8 12.5 3.8c4.4 0 6.6 2.5 6.7 8.1l1.8-.1C20.9 5.3 17.6 2 12.5 2zm-1 12.6c-.9 0-1.5-.5-1.5-1.2.1-.9 1-1.4 2.5-1.3h.4c-.2 1.5-.8 2.5-1.4 2.5z"
							/>
						</svg>
					</a>
				)
			}
			{
				SOCIAL.github && (
					<a
						href={SOCIAL.github}
						target="_blank"
						rel="noopener"
						aria-label="GitHub"
					>
						<span class="sr-only">GitHub</span>
						<svg viewBox="0 0 16 16" width="22" height="22" aria-hidden="true">
							<path
								fill="currentColor"
								d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
							/>
						</svg>
					</a>
				)
			}
		</div>
	</nav>
</header>

<style>
	header {
		background: var(--paper-raised);
		border-bottom: 1px solid var(--line);
	}
	nav {
		width: var(--maxw-wide);
		max-width: calc(100% - 2.5em);
		margin-inline: auto;
		display: flex;
		align-items: center;
		gap: 1.2rem;
		padding: 0.9rem 0;
	}
	.brand {
		font-family: var(--font-serif), Georgia, serif;
		font-weight: 900;
		font-size: 1.3rem;
		color: var(--ink-strong);
		text-decoration: none;
		margin-right: auto;
		letter-spacing: 0.01em;
	}
	.internal-links {
		display: flex;
		gap: 0.4rem;
	}
	.internal-links :global(a) {
		color: var(--ink);
		text-decoration: none;
		padding: 0.3em 0.6em;
		border-radius: 8px;
		font-size: 0.98rem;
	}
	.internal-links :global(a:hover) {
		background: var(--accent-soft);
		color: var(--accent-strong);
	}
	.internal-links :global(a.active) {
		color: var(--accent);
		font-weight: 700;
	}
	.social-links {
		display: flex;
		gap: 0.6rem;
	}
	.social-links a {
		color: var(--ink-soft);
		display: flex;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.brand {
			font-size: 1.15rem;
		}
		.internal-links :global(a) {
			padding: 0.3em 0.4em;
			font-size: 0.92rem;
		}
	}
</style>
