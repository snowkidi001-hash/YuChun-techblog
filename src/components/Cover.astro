---
// 自動封面：依分類自動生成的色塊封面（零檔案、零版權、風格統一）。
// 特色：標點處智慧斷行、字級隨標題長度自適應。
import { CATEGORIES, type Category } from '../consts';

interface Props {
	title: string;
	category: Category;
	variant?: 'card' | 'hero';
}

const { title, category, variant = 'card' } = Astro.props;
const { bg, fg, label } = CATEGORIES[category];

// 以「字數」決定字級（CJK 友善：用 code point 計數）
const len = Array.from(title).length;

// card / hero 兩套自適應級距（rem）
const scale =
	variant === 'hero'
		? len <= 8
			? 3.0
			: len <= 14
				? 2.5
				: len <= 22
					? 2.0
					: 1.7
		: len <= 8
			? 2.0
			: len <= 14
				? 1.6
				: len <= 22
					? 1.3
					: 1.1;

// 標點處智慧斷行：先跳脫 HTML，再於標點後插入 <wbr>。
// 搭配 CSS word-break: keep-all，CJK 只會在標點處換行。
const esc = (s: string) =>
	s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const smartTitle = esc(title).replace(
	/([，。、；：！？「」『』（）(),.!?:;—–…\s])/g,
	'$1<wbr />',
);
---

<div
	class={`cover ${variant}`}
	style={`--cv-bg:${bg};--cv-fg:${fg};--cv-size:${scale}rem;`}
	aria-hidden="true"
>
	<span class="cover-label">{label}</span>
	<span class="cover-title" set:html={smartTitle}></span>
</div>

<style>
	.cover {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		aspect-ratio: 16 / 9;
		width: 100%;
		padding: 1.4rem 1.6rem;
		background: var(--cv-bg);
		color: var(--cv-fg);
		border-radius: var(--radius);
		overflow: hidden;
	}
	.cover.hero {
		aspect-ratio: 21 / 9;
		border-radius: var(--radius);
	}
	.cover-label {
		position: absolute;
		top: 0.9rem;
		left: 1.1rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		opacity: 0.85;
		padding: 0.15em 0.6em;
		border: 1px solid currentColor;
		border-radius: 999px;
	}
	.cover-title {
		font-family: var(--font-serif), Georgia, serif;
		font-weight: 900;
		font-size: var(--cv-size);
		line-height: 1.25;
		text-align: center;
		word-break: keep-all; /* CJK 不逐字斷，只在 <wbr> 處斷 */
		overflow-wrap: break-word; /* 超長無標點時的保底 */
		max-width: 92%;
	}
	@media (max-width: 720px) {
		.cover-title {
			font-size: calc(var(--cv-size) * 0.82);
		}
	}
</style>
