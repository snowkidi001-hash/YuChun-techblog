---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Cover from '../components/Cover.astro';
import CategoryTag from '../components/CategoryTag.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, tags, source } =
	Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="cover-wrap">
					<Cover title={title} category={category} variant="hero" />
				</div>
				<div class="prose">
					<div class="meta">
						<CategoryTag category={category} />
						<span class="dot-sep">·</span>
						<span class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span class="updated">
										（更新於 <FormattedDate date={updatedDate} />）
									</span>
								)
							}
						</span>
					</div>
					<h1>{title}</h1>
					<p class="lede">{description}</p>
					{
						source && (
							<p class="source">
								資料來源：
								<a href={source.url} target="_blank" rel="noopener">
									{source.name}
								</a>
							</p>
						)
					}
					{
						tags && tags.length > 0 && (
							<ul class="tags">
								{tags.map((t) => (
									<li>#{t}</li>
								))}
							</ul>
						)
					}
					<hr />
					<div class="content">
						<slot />
					</div>
					<aside class="cta">
						<p class="cta-title">想更深入一點？</p>
						<p class="cta-body">
							這個主題若對你的工作有幫助，歡迎了解我的課程與顧問服務。
						</p>
						<a class="cta-link" href="/about">了解更多 →</a>
					</aside>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.cover-wrap {
		width: var(--maxw);
		max-width: calc(100% - 2.5em);
		margin: 0 auto 2rem;
	}
	.prose {
		width: var(--maxw);
		max-width: calc(100% - 2.5em);
		margin-inline: auto;
		text-align: left;
	}
	.meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		color: var(--ink-soft);
		font-size: 0.9rem;
		margin-bottom: 0.8rem;
	}
	.dot-sep {
		opacity: 0.5;
	}
	.updated {
		font-size: 0.85rem;
	}
	h1 {
		margin: 0 0 0.6rem;
	}
	.lede {
		font-size: 1.15rem;
		color: var(--ink-soft);
		margin: 0 0 1rem;
		line-height: 1.7;
	}
	.source {
		font-size: 0.9rem;
		color: var(--ink-soft);
		margin: 0 0 0.6rem;
	}
	.tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		padding: 0;
		margin: 0.4rem 0 0;
	}
	.tags li {
		font-size: 0.82rem;
		color: var(--accent);
		background: var(--accent-soft);
		padding: 0.1em 0.6em;
		border-radius: 999px;
		margin: 0;
	}
	.content :global(h2),
	.content :global(h3) {
		font-family: var(--font-sans), system-ui, sans-serif;
		font-weight: 700;
	}
	.cta {
		margin-top: 3rem;
		padding: 1.6rem 1.8rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--accent-soft);
	}
	.cta-title {
		font-family: var(--font-serif), Georgia, serif;
		font-weight: 900;
		font-size: 1.2rem;
		color: var(--ink-strong);
		margin: 0 0 0.4rem;
	}
	.cta-body {
		margin: 0 0 0.8rem;
		color: var(--ink);
		font-size: 0.98rem;
	}
	.cta-link {
		font-weight: 700;
		text-decoration: none;
	}
</style>
